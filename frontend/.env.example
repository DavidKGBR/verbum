# Optional client-side telemetry. Both are gated — leave blank to disable.
# Vars are read at BUILD TIME (Vite inlines them into dist/), so set them
# before running `npm run build` or store them in `.env.production` (gitignored).

# Sentry DSN for the frontend project. Get it from sentry.io after creating
# a "browser" project. Without this, the app runs without error telemetry.
VITE_SENTRY_DSN=

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX). Get it from
# Firebase Console → Project settings → Integrations → Google Analytics,
# or directly from analytics.google.com after creating the GA4 property.
# When set, gtag.js loads with anonymize_ip=true and ad signals disabled.
VITE_GA4_MEASUREMENT_ID=

# Release tag shown in Sentry events. Defaults to "verbum-frontend@2.0.0".
# CI can set this to the git SHA for source-map alignment.
VITE_VERBUM_RELEASE=
