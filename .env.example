# ─── Bible Data Pipeline — Environment Variables ─────────────────────────────

# Logging
LOG_LEVEL=INFO

# Parallel processing
PARALLEL_WORKERS=4

# ─── GCP Configuration (optional) ────────────────────────────────────────────
USE_GCP=false
GCP_PROJECT_ID=your-gcp-project-id
GCP_BUCKET_NAME=your-bucket-name
BQ_DATASET=bible_analytics

# ─── Multi-Translation (v2) ──────────────────────────────────────────────────
# Comma-separated translation IDs: kjv, asv, rva, nvi, ara
# TRANSLATIONS=kjv,asv

# A Bíblia Digital API token (required for NVI/ARA translations)
# Register at: https://www.abibliadigital.com.br/
# ABIBLIA_DIGITAL_TOKEN=your-token-here

# ─── API Configuration ───────────────────────────────────────────────────────
# GEMINI_API_KEY=your-gemini-key    # For future NLP enrichments

# ─── Bible Brain (Faith Comes By Hearing) — audio per chapter ────────────────
# Free for non-commercial/ministry use. Register at: https://4.dbt.io
# BIBLE_BRAIN_API_KEY=your-key-here
